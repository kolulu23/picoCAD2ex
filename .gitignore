# --- picoCAD user data & outputs ---------------------------------------------
.picocad/
backups/
output/
settings.json
skrovet.log

# picoCAD-generated artifacts (PNG textures, GLTF/OBJ exports, GIFs, binaries).
# Exceptions are forced-added via `git add -f` when a rendered preview is
# checked in deliberately (see `assets/football.gif`, the README demo).
*.png
*.gif
*.gltf
*.bin
*.obj
*.mtl
*.dll
*.exe

# Example export artifacts (binaries/sprites/pdfs) -- never track, but DO
# keep the example *.txt model files (see `examples/.gitignore`).
examples/*.png
examples/*.gltf
examples/*.bin

# --- Python -------------------------------------------------------------------
# uv-managed virtualenv (regenerated via `uv sync`)
.venv/

# Python bytecode caches
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# Tool caches
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Build / dist artifacts
build/
dist/

# Generated model files
models/

# Allow the README demo GIF (the only GIF intentionally tracked in repo).
!assets/football.gif

.DS_Store